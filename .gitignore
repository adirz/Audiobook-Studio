# Standard Python ignores

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]

# C extensions
*.so

# Distribution / packaging
build/
dist/
eggs/
*.egg-info/
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
.pytest_cache/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
hypothesis/

# Type checkers
.mypy_cache/
.pyre/

# IDEs and editors
.idea/
.vscode/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# macOS
.DS_Store

# Environment / secrets
.env
.env.*

# Databases
*.sqlite3

# Logs
*.log

# ToDo files
AUDIT.md

# Local settings
local_settings.py

# Ignore user project exports and large media directories
projects/*

